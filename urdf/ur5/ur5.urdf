<?xml version="1.0"?>
<robot name="ur5">
  <link name="base_link" />

  <link name="base_link_inertia">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.141592653589793" />
      <geometry>
        <mesh filename="meshes/ur5/visual/base.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 3.141592653589793" />
      <geometry>
        <mesh filename="meshes/ur5/collision/base.stl" />
      </geometry>
    </collision>
  </link>

  <link name="shoulder_link">
