      <geometry>
        <mesh filename="meshes/ur5/visual/shoulder.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 3.141592653589793" />
      <geometry>
        <mesh filename="meshes/ur5/collision/shoulder.stl" />
      </geometry>
    </collision>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.13585" rpy="1.570796326794897 0 -1.570796326794897" />
      <geometry>
        <mesh filename="meshes/ur5/visual/upperarm.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.13585" rpy="1.570796326794897 0 -1.570796326794897" />
      <geometry>
        <mesh filename="meshes/ur5/collision/upperarm.stl" />
